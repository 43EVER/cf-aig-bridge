{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-aig-bridge",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-06",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "AI_GATEWAY_ID": "default",
    "DEFAULT_IMAGE_MODEL": "gpt-image-2",
    "PUBLIC_MODEL_PREFIX": ""
  }
}
